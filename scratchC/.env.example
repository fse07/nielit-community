# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it's in .gitignore for a reason.
# ─────────────────────────────────────────────────────────────

# The public DNS name the app is served at. Must point at this VM's public IP
# BEFORE you run `docker compose up`, otherwise Caddy can't get a cert.
APP_DOMAIN=edtech05.centralindia.cloudapp.azure.com

# Let's Encrypt will send renewal/expiry notices here.
ADMIN_EMAIL=you@example.com

# What the app calls itself in the UI (<title>, topbar, auth splash).
APP_NAME=Nielit Community

# ─── Secrets ───────────────────────────────────────────────
# Generate both with:  openssl rand -base64 48
SECRET_KEY=REPLACE_WITH_48_RANDOM_CHARS

# Database is internal to the docker network, but still set a strong password.
DB_NAME=nielit_community
DB_USER=nielit
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ─── Tunables ──────────────────────────────────────────────
# Hard upload cap (MB). Videos are additionally capped to 50 MB; this value
# should be a bit larger than that to allow multi-image albums.
MAX_CONTENT_LENGTH_MB=55

# VCS
.git
.gitignore
.gitattributes

# Secrets & env
.env
.env.*
!.env.example
*.key
*.pem

# Python junk
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# SQLite dev DBs
*.sqlite
